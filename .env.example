# ==============================================================================
# BgRemove-ComfyUI — Variables de Entorno
# Copia este archivo como .env y ajusta los valores a tu entorno.
# NUNCA subas el archivo .env al repositorio.
# ==============================================================================

# URL del servidor ComfyUI (sin barra final)
COMFY_URL=http://127.0.0.1:8188

# Puerto del servidor Express
PORT=3000

# ID del nodo que carga el logo en el workflow.json
COMFY_NODE_LOGO_ID=13

# ID del nodo SaveImage (salida) en el workflow.json
COMFY_NODE_OUTPUT_ID=5

# URL de reseña de Google que se adjunta al mensaje de WhatsApp
GOOGLE_REVIEW_URL=https://g.page/r/CWAYKlgUL2eKEAE/review

# Prefijo telefónico por defecto (se antepone si el número tiene 9 dígitos)
PHONE_PREFIX=34

# Nombre del archivo de fondo en el directorio input de ComfyUI
COMFY_BG_FILENAME=fondo (1).jpg

# Qué fracción de la altura del fondo ocupa la persona (0.1 - 1.0)
# 0.80 = 80% de la altura del fondo. Redúcelo si la persona sale muy grande.
PERSON_SCALE=0.80
